{
  "name": "agent-skill-lint",
  "version": "0.1.0",
  "description": "Linter for agent skill / rule files — Markdown with YAML frontmatter. Validates the frontmatter, slug, description triggers, and body so an agent loader will actually pick the skill up.",
  "license": "MIT",
  "author": "Jan Drabek <drabek.honza@gmail.com>",
  "homepage": "https://github.com/drabekj/agent-skill-lint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drabekj/agent-skill-lint.git"
  },
  "bugs": {
    "url": "https://github.com/drabekj/agent-skill-lint/issues"
  },
  "keywords": [
    "agent",
    "skill",
    "rule",
    "linter",
    "cli",
    "yaml",
    "frontmatter",
    "prompt-engineering",
    "markdown"
  ],
  "type": "module",
  "bin": {
    "agent-skill-lint": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
